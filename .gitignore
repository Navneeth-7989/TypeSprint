# Local AI assistant notes (not part of the app)
memory/
.claude/

# OS / editor cruft
.DS_Store
Thumbs.db
*.log

# Dependencies (not used, but just in case)
node_modules/

# Firebase local cache
.firebase/

# Secrets — never commit these
# NOTE: the Firebase *web* apiKey in firebase-init.js is public by design and is
# NOT a secret. The dangerous file is a service-account/Admin-SDK private key.
.env
.env.*
*.local.env
serviceAccount*.json
service-account*.json
*-serviceaccount.json
*firebase-adminsdk*.json
*.pem
*.p12
*.key
credentials.json
secrets.json
